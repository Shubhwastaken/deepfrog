DATABASE_URL=postgresql+asyncpg://db-user:db-password@localhost/customs_brain
REDIS_URL=redis://localhost:6379
SHARED_DATA_DIR=/app/data
UPLOAD_DIR=/app/data/uploads
REPORT_DIR=/app/data/reports
LOG_DIR=/app/data/logs
SECRET_KEY=replace-with-a-long-random-secret
PII_ENCRYPTION_KEY=replace-with-a-separate-long-random-secret
LOCAL_PIPELINE_MODE=false
LOCAL_DB_PATH=backend/data/customs_brain.db
AUTH_DEBUG_OTP_ECHO=false
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6
POSTGRES_USER=db-user
POSTGRES_PASSWORD=db-password
POSTGRES_DB=customs_brain
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace-grafana-admin-password
ADMIN_EMAIL=admin@customs.ai
ADMIN_PASSWORD=change-this-password
GENERAL_USER_EMAIL=
GENERAL_USER_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=auth@customsbrain.local
SMTP_USE_TLS=true
ANTHROPIC_API_KEY=your-anthropic-key-here
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=openai/gpt-oss-20b
GROQ_OCR_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
XAI_API_KEY=your-xai-key-here
XAI_MODEL=grok-4.20-beta-latest-non-reasoning
OPENAI_API_KEY=your-openai-key-here
