DATABASE_URL=postgresql+asyncpg://user:pass@localhost/customs_brain
REDIS_URL=redis://localhost:6379
SHARED_DATA_DIR=/app/data
UPLOAD_DIR=/app/data/uploads
REPORT_DIR=/app/data/reports
